# =============================================
# Environment Variables — Portfolio
# =============================================
# Salin file ini ke .env.local dan isi value-nya.
# JANGAN commit file .env.local ke Git.

# --- Chatbot AI (OpenAI-compatible API) ---
# Wajib diisi agar chatbot berfungsi.
AI_API_KEY=
# Opsional: base URL API (default: https://api.openai.com/v1)
AI_BASE_URL=
# Opsional: model yang digunakan (default: gpt-4o-mini)
AI_MODEL=

# --- Contact Form (Resend) ---
# Wajib diisi agar form kontak mengirim email.
# Daftar di https://resend.com untuk mendapatkan API key.
RESEND_API_KEY=
# Email tujuan penerima pesan dari form kontak.
CONTACT_EMAIL=
